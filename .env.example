# Supabase public browser values
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only Supabase service role key.
# Never expose this in frontend code and never commit a real value.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_server_only

# Stripe test mode only.
# STRIPE_SECRET_KEY=your_stripe_test_secret_key
# STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_test_publishable_key

# Claude API server-side only.
# ANTHROPIC_API_KEY=your_claude_api_key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# App URL used for Stripe redirects and auth callbacks.
# NEXT_PUBLIC_APP_URL=http://localhost:3000
